{
  "name": "LuaAttachDebuger",
  "displayName": "LuaAttachDebug",
  "description": "Attach or launch Windows Lua processes with Lua native debugger tools.",
  "version": "1.0.0",
  "publisher": "kibernet",
  "repository": { "type": "git", "url": "https://github.com/kibernet/LuaAttachDebug" },
  "license": "Apache-2.0",
  "icon": "images/icon.png",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Debuggers", "Other"],
  "activationEvents": ["onCommand:luaAttachDebug.attachByPid", "onCommand:luaAttachDebug.pickAndAttach", "onCommand:luaAttachDebug.launchAndAttach"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "luaAttachDebug.pickAndAttach", "title": "LuaAttachDebug: Pick Process and Attach" },
      { "command": "luaAttachDebug.attachByPid", "title": "LuaAttachDebug: Attach by PID" },
      { "command": "luaAttachDebug.launchAndAttach", "title": "LuaAttachDebug: Launch and Attach" }
    ],
    "configuration": {
      "title": "LuaAttachDebug",
      "properties": {
        "luaAttachDebug.encoding": { "type": "string", "default": "gbk", "description": "Encoding used when reading process titles from emmy_tool.exe." },
        "luaAttachDebug.luaProgram": { "type": "string", "default": "lua", "description": "Default Lua executable for launch-and-attach." },
        "luaAttachDebug.luaArguments": { "type": "string", "default": "", "description": "Default arguments passed to the launched Lua program." },
        "luaAttachDebug.workingDirectory": { "type": "string", "default": "${workspaceFolder}", "description": "Default working directory for launch-and-attach." }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package:vsix": "vsce package -o LuaAttachDebug-%npm_package_version%.vsix"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.0.0"
  }
}
